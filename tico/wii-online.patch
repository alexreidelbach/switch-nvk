@@ -419,6 +421,23 @@ static std::optional<DefaultInterface> GetSystemDefaultInterface()
   if (!default_interface_address)
     return {};
 
+#ifdef __SWITCH__
+  // libnx has no getifaddrs(); synthesize a /24 interface around the address
+  // learned from the connected-UDP getsockname trick above. The emulated Wii
+  // only reports these values to the game; real traffic uses host sockets.
+  {
+    const in_addr ip = *default_interface_address;
+    in_addr netmask;
+    netmask.s_addr = inet_addr("255.255.255.0");
+    in_addr broadcast;
+    broadcast.s_addr = ip.s_addr | ~netmask.s_addr;
+    in_addr gateway;
+    gateway.s_addr = (ip.s_addr & netmask.s_addr) | htonl(1u);
+    if (routing_table.empty())
+      routing_table = {{0, {}, {}, gateway}};
+    return DefaultInterface{ip, netmask, broadcast, routing_table};
+  }
+#else
   ifaddrs* iflist;
   if (getifaddrs(&iflist) != 0)
     return {};
