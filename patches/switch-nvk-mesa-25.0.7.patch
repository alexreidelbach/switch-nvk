+extern void (*g_drm_shim_log_sink)(const char *);
+static void switch_nvk_image_log(const char *msg)
+{
+   /* switch-nvk: per-image trace is OFF unless NVK_TRACE is set — the per-frame
+    * volume throttles the SD/nxlink sink and costs real fps. */
+   static int en = -1;
