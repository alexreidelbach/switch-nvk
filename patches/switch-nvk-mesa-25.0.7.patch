+ * wsi_common_switch.c can wrap the image's bound memory in an NvGraphicBuffer
+ * that the VI compositor scans out directly (kills the per-frame present memcpy
+ * the profiling found). All fields come from the image's nil_image; the matching
+ * nvmap id + size come from drm_shim_bo_nvmap_by_va() over the image's GPU VA. */
+bool nvk_switch_image_layout(VkImage _image, uint32_t *row_stride_B,
