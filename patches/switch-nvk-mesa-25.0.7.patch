+                             uint64_t *size_B, uint8_t *pte_kind,
+                             uint64_t *gpu_va);
+bool nvk_switch_image_layout(VkImage _image, uint32_t *row_stride_B,
+                             uint32_t *block_height_log2, uint64_t *offset_B,
+                             uint64_t *size_B, uint8_t *pte_kind,
+                             uint64_t *gpu_va)
+{
+   VK_FROM_HANDLE(nvk_image, image, _image);
+   if (image == NULL || image->plane_count < 1)
+      return false;
+   const struct nil_image *nil = &image->planes[0].nil;
+   if (row_stride_B)      *row_stride_B      = nil->levels[0].row_stride_B;
+   if (block_height_log2) *block_height_log2 = nil->levels[0].tiling.y_log2;
+   if (offset_B)          *offset_B          = nil->levels[0].offset_B;
+   if (size_B)            *size_B            = nil->size_B;
+   if (pte_kind)          *pte_kind          = nil->pte_kind;
+   if (gpu_va)            *gpu_va            = image->planes[0].addr; /* bound GPU VA */
+   return true;
+}
